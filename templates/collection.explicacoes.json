ont-size: 18px;\n  margin-bottom: 5px;\n  font-weight: 600;\n}\n\n.disc-card p {\n  font-size: 15px;\n  opacity: 0.85;\n}\n\n\/* VANTAGENS *\/\n.checklist {\n  list-style: none;\n  padding: 0;\n  margin-bottom: 35px;\n}\n\n.checklist li {\n  position: relative;\n  padding-left: 32px;\n  margin-bottom: 14px;\n  font-size: 16px;\n  line-height: 1.5;\n}\n\n.checklist li::before {\n  content: \"✔\";\n  position: absolute;\n  left: 0;\n  color: #6FAE8C;\n  font-weight: bold;\n  font-size: 18px;\n}\n\n\/* BOTÃO *\/\n.btn-primeira-aula {\n  display: inline-block;\n  background-color: #8C7B6D;\n  color: white;\n  padding: 16px 32px;\n  border-radius: 40px;\n  text-decoration: none;\n  font-weight: 600;\n  transition: 0.3s ease;\n}\n\n.btn-primeira-aula:hover {\n  background-color: #8C7B6D;\n  transform: translateY(-3px);\n}\n\n\/* RESPONSIVO *\/\n@media (max-width: 900px) {\n  .explicadores-grid {\n    grid-template-columns: 1fr;\n    gap: 50px;\n  }\n\n  .intro-explicadores h2 {\n    font-size: 32px;\n  }\n}\n\n<\/style>","background_color":"{{ settings.color_palette.background }}","section_width":"page-width","padding-block-start":0,"padding-block-end":0}},"custom_liquid_FVQUP6":{"type":"custom-liquid","name":"t:names.custom_liquid","settings":{"custom_liquid":"<!-- GOOGLE FONT -->\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n<section class=\"bio-section\">\n\n  <div class=\"bio-container\">\n\n    <h2>Biologia e Geologia<\/h2>\n\n    <p class=\"bio-descricao\">\n      Explicações individuais para o Ensino Secundário com acompanhamento\n      personalizado e foco total na melhoria das tuas notas.\n    <\/p>\n\n    <div class=\"bio-card\">\n      <h3>Ensino Secundário<\/h3>\n      <p class=\"disciplina\">Biologia e Geologia<\/p>\n      <p class=\"preco\">6€ <span>por hora<\/span><\/p>\n\n      <ul>\n        <li>Aulas individuais personalizadas<\/li>\n        <li>Preparação para testes e exames<