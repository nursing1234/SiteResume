alc-wrapper {\n    max-width: 760px;\n    margin: 18px auto;\n    padding: 20px;\n    border: 1px solid #e6e6e6;\n    border-radius: 14px;\n    background: #ffffff;\n    font-family: Inter, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.03);\n  }\n\n  .calc-top {\n    display:flex;\n    justify-content:space-between;\n    align-items:flex-start;\n    gap: 20px;\n  }\n\n  .calc-title {\n    margin: 0;\n    font-size: 18px;\n    font-weight:600;\n  }\n\n  .calc-note {\n    font-size:13px;\n    color:#666;\n    line-height:1.4;\n  }\n\n  .calc-note div {\n    text-align:right;\n  }\n\n  .calc-row {\n    display: flex;\n    gap: 16px;\n    margin-top: 14px;\n  }\n\n  .calc-field {\n    flex: 1;\n    min-width: 220px;\n    display: flex;\n    flex-direction: column;\n  }\n\n  label.small {\n    font-size: 13px;\n    margin-bottom:6px;\n    color:#444;\n  }\n\n  .calc-field input[type=\"number\"],\n  .calc-field select {\n    padding: 12px;\n    border: 1px solid #d0d0d0;\n    border-radius: 12px;\n    font-size: 15px;\n    outline: none;\n  }\n\n  .calc-footer {\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap: 16px;\n    margin-top: 18px;\n    flex-wrap: wrap;\n  }\n\n  .calc-result {\n    font-weight:700;\n    font-size:18px;\n  }\n\n  .btn-calc {\n    padding: 11px 16px;\n    border-radius: 12px;\n    background: #111;\n    color: #fff;\n    border: none;\n    font-weight:600;\n    cursor: pointer;\n  }\n\n  @media (max-width: 700px) {\n    .calc-row { flex-direction: column; }\n    .calc-top { flex-direction: column; align-items: flex-start; gap:8px; }\n    .calc-note div { text-align:left; }\n    .calc-footer { flex-direction: column; align-items: stretch; }\n    .calc-result { width:100%; }\n    .btn-calc { width:100%; }\n  }\n<\/style>\n\n<div class=\"calc-wrapper\">\n  <div class=\"calc-top\">\n    <h3 class=\"calc-title\">Calculadora de Impressão & Encadernação<\/h3>\n\n    <div class=\"calc-note\">\n      <div>Preto e Branco: <strong>0,06€\/página<\/strong><\/div>\n      <div>Cores: <strong>0,20€\/página<\/strong><\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"calc-row\">\n    <div class=\"calc-field\">\n      <label class=\"small\">Tipo de impressão<\/label>\n      <select id=\"printType\">\n        <option value=\"pb\">Preto e Branco — 0,06€\/página<\/option>\n        <option value=\"color\">Cores — 0,20€\/página<\/option>\n      <\/select>\n    <\/div>\n\n    <div class=\"calc-field\">\n      <label class=\"small\">Número de páginas (máx. 300)<\/label>\n      <input id=\"pages\" type=\"number\" min=\"1\" max=\"300\" step=\"1\" placeholder=\"Ex.: 45\">\n    <\/div>\n\n    <div class=\"calc-field\">\n      <label class=\"small\">Encadernação<\/label>\n      <select id=\"binding\">\n        <option value=\"nenhuma\">Nenhuma (0€)<\/option>\n        <option value=\"normal\">Normal (+2,20€)<\/option>\n        <option value=\"capadura\">Capa dura (+3,50€)<\/option>\n      <\/select>\n    <\/div>\n  <\/div>\n\n  <div class=\"calc-footer\">\n    <div class=\"calc-result\" id=\"result\">Preço estimado: —<\/div>\n    <button class=\"btn-calc\" id=\"calcBtn\">Calcular preço<\/button>\n  <\/div>\n<\/div>\n\n<script>\n(function(){\n  const pagesInput = document.getElementById('pages');\n  const printType = document.getElementById('printType');\n  const bindingSel = document.getElementById('binding');\n  const resultEl = document.getElementById('result');\n  const calcBtn = document.getElementById('calcBtn');\n\n  const MAX_PAGES = 300;\n  const PAGES_PER_BLOCK = 10;\n\n  const blockPrices = {\n    pb: 0.60,\n    color: 2.00\n  };\n\n  const bindingPrices = {\n    nenhuma: 0,\n    normal: 2.20,\n    capadura: 3.50\n  };\n\n  function computeAndShow() {\n    let pages = Number(pagesInput.value);\n    if (!pages || pages < 1) {\n      resultEl.textContent = 'Preço estimado: —';\n      return;\n    }\n\n    if (pages > MAX_PAGES) pages = MAX_PAGES;\n\n    const blocks = Math.ceil(pages \/ PAGES_PER_BLOCK);\n    const printCost = blocks * blockPrices[printType.value];\n    const bindingCost = bindingPrices[bindingSel.value];\n\n    resultEl.textContent =\n      'Preço estimado: ' + (printCost + bindingCost).toFixed(2) + '€';\n  }\n\n  pagesInput.addEventListener('input', computeAndShow);\n  printType.addEventListener('change', computeAndShow);\n  bindingSel.addEventListener('change', computeAndShow);\n  calcBtn.addEventListener('click', computeAndShow);\n})();\n<\/script>","background_color":"{{ settings.color_palette.background }}","section_width":"page-width","padding-block-start":0,"padding-block-end":0}},"section_VAUAhD":{"type":"section","blocks":{"text_DjLnWJ":{"type":"text","name":"t:names.heading","settings":{"text":"<h2>Como pedir?<\/h2>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_AActUq":{"type":"text","name":"t:names.text","settings":{"text":"<p>Basta seguir as instruções a baixo:<\/p>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_DjLnWJ","text_AActUq"],"name":"t:names.rich_text_section","settings":{"content_direction":"column","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direct