<section class="resume-study-flow resume-study-flow-{{ section.id }}">
  <div class="resume-study-flow__inner">
    <div class="resume-study-flow__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-study-flow__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="resume-study-flow__title">{{ section.settings.title | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="resume-study-flow__text">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="resume-study-flow__layout">
      <div class="resume-study-flow__steps">
        {% for block in section.blocks %}
          <details class="resume-study-flow__step" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
            <summary>
              <span class="resume-study-flow__step-index">{{ forloop.index }}</span>
              <span class="resume-study-flow__step-title">{{ block.settings.title | escape }}</span>
            </summary>
            <p>{{ block.settings.text | escape }}</p>
            {% if block.settings.link_label != blank %}
              <a href="{{ block.settings.link | default: '#' }}">{{ block.settings.link_label | escape }}</a>
            {% endif %}
          </details>
        {% endfor %}
      </div>

      <div class="resume-study-flow__board" aria-hidden="true">
        <div class="resume-study-flow__board-header">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="resume-study-flow__board-card resume-study-flow__board-card--focus">
          <small>{{ section.settings.board_label | escape }}</small>
          <strong>{{ section.settings.board_title | escape }}</strong>
        </div>
        <div class="resume-study-flow__mini-grid">
          <div>
            <small>{{ section.settings.metric_1_label | escape }}</small>
            <strong>{{ section.settings.metric_1_value | escape }}</strong>
          </div>
          <div>
            <small>{{ section.settings.metric_2_label | escape }}</small>
            <strong>{{ section.settings.metric_2_value | escape }}</strong>
          </div>
        </div>
        <div class="resume-study-flow__progress">
          <span></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .resume-study-flow-{{ section.id }} {
    --resume-flow-bg: {{ section.settings.background_color }};
    --resume-flow-text: {{ section.settings.text_color }};
    --resume-flow-accent: {{ section.settings.accent_color }};
    --resume-flow-soft: {{ section.settings.soft_color }};
    background: linear-gradient(180deg, var(--resume-flow-bg), #ffffff);
    color: var(--resume-flow-text);
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 46px 0 58px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__intro {
    max-width: 820px;
    margin-bottom: 26px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__eyebrow {
    width: fit-content;
    margin: 0 0 12px;
    border-radius: 999px;
    padding: 8px 12px;
    background: color-mix(in srgb, var(--resume-flow-accent) 12%, white);
    color: var(--resume-flow-accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__title {
    max-width: 780px;
    margin: 0;
    color: inherit;
    font-size: clamp(1.9rem, 4.2vw, 3.25rem);
    line-height: 1.05;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__text {
    max-width: 680px;
    margin-top: 14px;
    color: color-mix(in srgb, var(--resume-flow-text) 72%, transparent);
    line-height: 1.55;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__text p {
    margin: 0;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__layout {
    display: grid;
    gap: 18px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__steps {
    display: grid;
    gap: 10px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step {
    border: 1px solid color-mix(in srgb, var(--resume-flow-text) 10%, transparent);
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 14px 36px rgba(22, 22, 24, 0.055);
    overflow: hidden;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step summary {
    min-height: 70px;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 12px;
    align-items: center;
    padding: 16px;
    cursor: pointer;
    list-style: none;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step summary::-webkit-details-marker {
    display: none;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step-index {
    width: 38px;
    height: 38px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--resume-flow-soft);
    color: var(--resume-flow-accent);
    font-weight: 850;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step-title {
    color: inherit;
    font-size: 1.05rem;
    font-weight: 800;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step p {
    margin: 0;
    padding: 0 18px 0 70px;
    color: color-mix(in srgb, var(--resume-flow-text) 70%, transparent);
    line-height: 1.5;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step a {
    display: inline-flex;
    margin: 14px 18px 18px 70px;
    color: var(--resume-flow-accent);
    font-weight: 800;
    text-decoration: none;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__step[open] {
    border-color: color-mix(in srgb, var(--resume-flow-accent) 24%, transparent);
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board {
    min-height: 320px;
    border-radius: 30px;
    padding: 20px;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--resume-flow-accent) 13%, #ffffff), #ffffff);
    box-shadow: 0 22px 62px rgba(70, 56, 43, 0.1);
    display: grid;
    align-content: space-between;
    gap: 16px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board-header {
    display: flex;
    gap: 8px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board-header span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--resume-flow-accent) 32%, white);
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board-card {
    border-radius: 24px;
    padding: 22px;
    background: color-mix(in srgb, var(--resume-flow-accent) 88%, #343434);
    color: #ffffff;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board-card small,
  .resume-study-flow-{{ section.id }} .resume-study-flow__mini-grid small {
    display: block;
    margin-bottom: 8px;
    opacity: 0.72;
    font-size: 0.8rem;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__board-card strong {
    display: block;
    max-width: 320px;
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    line-height: 1.08;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__mini-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__mini-grid div {
    border-radius: 20px;
    padding: 18px;
    background: color-mix(in srgb, white 82%, transparent);
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__mini-grid strong {
    font-size: 1.5rem;
    line-height: 1;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__progress {
    height: 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--resume-flow-text) 10%, transparent);
    overflow: hidden;
  }

  .resume-study-flow-{{ section.id }} .resume-study-flow__progress span {
    display: block;
    width: 72%;
    height: 100%;
    border-radius: inherit;
    background: var(--resume-flow-accent);
  }

  @media screen and (min-width: 900px) {
    .resume-study-flow-{{ section.id }} .resume-study-flow__inner {
      padding: 64px 0 72px;
    }

    .resume-study-flow-{{ section.id }} .resume-study-flow__layout {
      grid-template-columns: minmax(0, 0.94fr) minmax(340px, 1.06fr);
      align-items: stretch;
      gap: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Resume study flow",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta",
      "default": "A tua rotina de estudo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Entra, escolhe o que precisas e começa a estudar."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>A homepage deve funcionar como uma porta de entrada simples: app para organizar e treinar, loja para comprar resumos quando precisas de estudar já.</p>"
    },
    {
      "type": "text",
      "id": "board_label",
      "label": "Etiqueta do painel",
      "default": "Plano de hoje"
    },
    {
      "type": "text",
      "id": "board_title",
      "label": "Titulo do painel",
      "default": "30 min de foco + 1 quiz + revisão por resumo"
    },
    {
      "type": "text",
      "id": "metric_1_label",
      "label": "Metrica 1 etiqueta",
      "default": "Materias"
    },
    {
      "type": "text",
      "id": "metric_1_value",
      "label": "Metrica 1 valor",
      "default": "8+"
    },
    {
      "type": "text",
      "id": "metric_2_label",
      "label": "Metrica 2 etiqueta",
      "default": "Ferramentas"
    },
    {
      "type": "text",
      "id": "metric_2_value",
      "label": "Metrica 2 valor",
      "default": "Tudo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#fbfaf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#2b2520"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor principal",
      "default": "#756251"
    },
    {
      "type": "color",
      "id": "soft_color",
      "label": "Cor suave",
      "default": "#efe8df"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Passo",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Passo de estudo"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Explica como este passo ajuda o aluno."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Texto do link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Resume study flow",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Organiza o que tens de estudar",
            "text": "Começa por perceber disciplinas, objetivos e tempo disponível."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Aprende com resumos e IA",
            "text": "Usa explicações simples, resumos prontos e materiais por disciplina."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Treina com quizzes e exames",
            "text": "Pratica antes dos testes para descobrir onde ainda precisas de melhorar."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Reforça com a loja",
            "text": "Quando precisas de estudar já, compra resumos organizados por disciplina."
          }
        }
      ]
    }
  ]
}
{% endschema %}
