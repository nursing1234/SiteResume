{% liquid
  assign selected_collection = section.settings.collection
  assign max_products = section.settings.max_products
%}

<section class="resume-featured-products resume-featured-products-{{ section.id }}">
  <div class="resume-featured-products__inner">
    <div class="resume-featured-products__header">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-featured-products__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="resume-featured-products__title">{{ section.settings.title | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="resume-featured-products__text">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="resume-featured-products__grid">
      {% if selected_collection != blank and selected_collection.products_count > 0 %}
        {% for product in selected_collection.products limit: max_products %}
          <a class="resume-featured-products__card" href="{{ product.url }}">
            <div class="resume-featured-products__media">
              {% if product.featured_image != blank %}
                {{
                  product.featured_image
                  | image_url: width: 700
                  | image_tag:
                    widths: '260, 360, 520, 700',
                    sizes: '(min-width: 990px) 23vw, (min-width: 640px) 46vw, 92vw',
                    loading: 'lazy',
                    class: 'resume-featured-products__image',
                    alt: product.featured_image.alt
                }}
              {% else %}
                <div class="resume-featured-products__placeholder">
                  <span>{{ section.settings.placeholder_label | escape }}</span>
                </div>
              {% endif %}
            </div>

            <div class="resume-featured-products__body">
              {% if section.settings.badge_label != blank %}
                <span class="resume-featured-products__badge">{{ section.settings.badge_label | escape }}</span>
              {% endif %}
              <h3>{{ product.title | escape }}</h3>
              <div class="resume-featured-products__meta">
                <span>{{ product.price | money }}</span>
                <span>{{ section.settings.card_link_label | escape }}</span>
              </div>
            </div>
          </a>
        {% endfor %}
      {% else %}
        {% for index in (1..4) %}
          <article class="resume-featured-products__card">
            <div class="resume-featured-products__media">
              <div class="resume-featured-products__placeholder">
                <span>{{ section.settings.placeholder_label | escape }}</span>
              </div>
            </div>
            <div class="resume-featured-products__body">
              <span class="resume-featured-products__badge">{{ section.settings.badge_label | escape }}</span>
              <h3>Resumo em destaque</h3>
              <div class="resume-featured-products__meta">
                <span>€0,00</span>
                <span>{{ section.settings.card_link_label | escape }}</span>
              </div>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="resume-featured-products__footer">
        <a class="resume-featured-products__button" href="{{ section.settings.button_link | default: selected_collection.url | default: '#' }}">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .resume-featured-products-{{ section.id }} {
    --resume-products-bg: {{ section.settings.background_color }};
    --resume-products-text: {{ section.settings.text_color }};
    --resume-products-accent: {{ section.settings.accent_color }};
    background: var(--resume-products-bg);
    color: var(--resume-products-text);
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 48px 0 68px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__header {
    max-width: 720px;
    margin-bottom: 24px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__eyebrow {
    margin: 0 0 10px;
    color: var(--resume-products-accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__title {
    margin: 0;
    color: inherit;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    line-height: 1.06;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__text {
    margin-top: 12px;
    color: color-mix(in srgb, var(--resume-products-text) 68%, transparent);
    line-height: 1.5;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__text p {
    margin: 0;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 16px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__card {
    min-width: 0;
    border: 1px solid color-mix(in srgb, var(--resume-products-text) 10%, transparent);
    border-radius: 24px;
    overflow: hidden;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 16px 42px rgba(70, 56, 43, 0.07);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--resume-products-accent) 26%, transparent);
    box-shadow: 0 22px 54px rgba(70, 56, 43, 0.12);
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__media {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--resume-products-accent) 7%, #ffffff);
    padding: 22px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__placeholder {
    width: 72%;
    height: 82%;
    border-radius: 18px;
    display: grid;
    place-items: center;
    background: #ffffff;
    color: var(--resume-products-accent);
    font-weight: 900;
    box-shadow: 0 14px 32px rgba(70, 56, 43, 0.08);
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__body {
    padding: 18px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__badge {
    display: inline-flex;
    margin-bottom: 10px;
    border-radius: 999px;
    padding: 6px 9px;
    background: color-mix(in srgb, var(--resume-products-accent) 10%, #ffffff);
    color: var(--resume-products-accent);
    font-size: 0.72rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__body h3 {
    min-height: 2.5em;
    margin: 0;
    color: inherit;
    font-size: 1rem;
    line-height: 1.25;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 16px;
    color: color-mix(in srgb, var(--resume-products-text) 72%, transparent);
    font-weight: 800;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__meta span:last-child {
    color: var(--resume-products-accent);
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__footer {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .resume-featured-products-{{ section.id }} .resume-featured-products__button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 22px;
    background: var(--resume-products-accent);
    color: #ffffff;
    text-decoration: none;
    font-weight: 850;
  }

  @media screen and (min-width: 640px) {
    .resume-featured-products-{{ section.id }} .resume-featured-products__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .resume-featured-products-{{ section.id }} .resume-featured-products__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>

{% schema %}
{
  "name": "Resume featured products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Colecao"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Numero de produtos",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta",
      "default": "Loja"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "Resumos em destaque"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Escolhe um resumo e abre a pagina do produto para ver todos os detalhes antes de comprar.</p>"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Etiqueta dos cards",
      "default": "Resumo"
    },
    {
      "type": "text",
      "id": "card_link_label",
      "label": "Texto do link no card",
      "default": "Ver"
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "Texto do placeholder",
      "default": "R"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botao final",
      "default": "Ver todos os resumos"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do botao final"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#2b2520"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor principal",
      "default": "#756251"
    }
  ],
  "presets": [
    {
      "name": "Resume featured products"
    }
  ]
}
{% endschema %}
