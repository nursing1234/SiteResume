<section class="resume-home-options resume-home-options-{{ section.id }}">
  <div class="resume-home-options__inner">
    <div class="resume-home-options__header">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-home-options__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2>{{ section.settings.title | escape }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="resume-home-options__text">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="resume-home-options__grid">
      {% for block in section.blocks %}
        <a class="resume-home-options__card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <span class="resume-home-options__symbol">{{ block.settings.symbol | escape }}</span>
          <span class="resume-home-options__content">
            <strong>{{ block.settings.title | escape }}</strong>
            <small>{{ block.settings.text | escape }}</small>
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .resume-home-options-{{ section.id }} {
    --resume-options-bg: {{ section.settings.background_color }};
    --resume-options-text: {{ section.settings.text_color }};
    --resume-options-accent: {{ section.settings.accent_color }};
    background: var(--resume-options-bg);
    color: var(--resume-options-text);
  }

  .resume-home-options-{{ section.id }} .resume-home-options__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 42px 0 34px;
    display: grid;
    gap: 24px;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__header {
    max-width: 620px;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__eyebrow {
    margin: 0 0 10px;
    color: var(--resume-options-accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .resume-home-options-{{ section.id }} h2 {
    margin: 0;
    color: inherit;
    font-size: clamp(2rem, 4.2vw, 3.35rem);
    line-height: 1.04;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__text {
    margin-top: 12px;
    color: color-mix(in srgb, var(--resume-options-text) 68%, transparent);
    line-height: 1.5;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__text p {
    margin: 0;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 14px;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__card {
    min-height: 150px;
    border: 1px solid color-mix(in srgb, var(--resume-options-text) 10%, transparent);
    border-radius: 24px;
    padding: 20px;
    background: #ffffff;
    color: inherit;
    text-decoration: none;
    display: grid;
    grid-template-columns: 46px 1fr;
    gap: 16px;
    align-items: start;
    box-shadow: 0 16px 44px rgba(70, 56, 43, 0.07);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--resume-options-accent) 28%, transparent);
    box-shadow: 0 22px 54px rgba(70, 56, 43, 0.12);
  }

  .resume-home-options-{{ section.id }} .resume-home-options__symbol {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--resume-options-accent) 12%, #ffffff);
    color: var(--resume-options-accent);
    font-weight: 900;
    font-size: 0.82rem;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__content strong,
  .resume-home-options-{{ section.id }} .resume-home-options__content small {
    display: block;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__content strong {
    color: inherit;
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .resume-home-options-{{ section.id }} .resume-home-options__content small {
    margin-top: 10px;
    color: color-mix(in srgb, var(--resume-options-text) 66%, transparent);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  @media screen and (min-width: 760px) {
    .resume-home-options-{{ section.id }} .resume-home-options__inner {
      grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);
      align-items: end;
    }

    .resume-home-options-{{ section.id }} .resume-home-options__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .resume-home-options-{{ section.id }} .resume-home-options__card {
      grid-template-columns: 1fr;
    }

    .resume-home-options-{{ section.id }} .resume-home-options__card:first-child {
      grid-row: span 2;
      min-height: 314px;
      align-content: space-between;
      background:
        linear-gradient(145deg, color-mix(in srgb, var(--resume-options-accent) 14%, #ffffff), #ffffff);
    }

    .resume-home-options-{{ section.id }} .resume-home-options__card:first-child .resume-home-options__content strong {
      font-size: 1.45rem;
    }
  }
</style>

{% schema %}
{
  "name": "Resume home options",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta",
      "default": "Escolhe o teu caminho"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "O que queres fazer hoje?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>A homepage fica mais simples: escolhe se queres estudar na app, comprar resumos, pedir explicacoes ou calcular a media.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#fbfaf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#2b2520"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor principal",
      "default": "#756251"
    }
  ],
  "blocks": [
    {
      "type": "option",
      "name": "Opcao",
      "settings": [
        {
          "type": "text",
          "id": "symbol",
          "label": "Simbolo",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titulo",
          "default": "Opcao"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Explica esta opcao."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Resume home options",
      "blocks": [
        {
          "type": "option",
          "settings": {
            "symbol": "APP",
            "title": "Usar a app",
            "text": "Organiza estudo, quizzes, flashcards e IA."
          }
        },
        {
          "type": "option",
          "settings": {
            "symbol": "R",
            "title": "Comprar resumos",
            "text": "Escolhe materiais por disciplina."
          }
        },
        {
          "type": "option",
          "settings": {
            "symbol": "?",
            "title": "Pedir explicações",
            "text": "Recebe apoio extra quando precisas."
          }
        },
        {
          "type": "option",
          "settings": {
            "symbol": "%",
            "title": "Calcular média",
            "text": "Simula notas e próximos passos."
          }
        }
      ]
    }
  ]
}
{% endschema %}
