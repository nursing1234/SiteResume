<section class="resume-shop-highlight resume-shop-highlight-{{ section.id }}">
  <div class="resume-shop-highlight__inner">
    <div class="resume-shop-highlight__content">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-shop-highlight__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="resume-shop-highlight__title">{{ section.settings.title | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="resume-shop-highlight__text">{{ section.settings.text }}</div>
      {% endif %}

      <div class="resume-shop-highlight__actions">
        {% if section.settings.button_label != blank %}
          <a class="resume-shop-highlight__button resume-shop-highlight__button--primary" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}

        {% if section.settings.secondary_button_label != blank %}
          <a class="resume-shop-highlight__button resume-shop-highlight__button--secondary" href="{{ section.settings.secondary_button_link | default: '#' }}">
            {{ section.settings.secondary_button_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="resume-shop-highlight__panel" aria-hidden="true">
      <div class="resume-shop-highlight__shelf">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <div class="resume-shop-highlight__note">{{ section.settings.panel_text | escape }}</div>
    </div>
  </div>
</section>

<style>
  .resume-shop-highlight-{{ section.id }} {
    --resume-shop-bg: {{ section.settings.background_color }};
    --resume-shop-card: {{ section.settings.card_color }};
    --resume-shop-text: {{ section.settings.text_color }};
    --resume-shop-accent: {{ section.settings.accent_color }};
    background: var(--resume-shop-bg);
    color: var(--resume-shop-text);
    overflow: hidden;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 64px 0;
    display: grid;
    gap: 22px;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__content,
  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__panel {
    border-radius: 32px;
    background: var(--resume-shop-card);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__content {
    padding: 30px;
    box-shadow: 0 18px 60px rgba(22, 22, 24, 0.07);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__eyebrow {
    margin: 0 0 10px;
    color: var(--resume-shop-accent);
    font-size: 0.82rem;
    font-weight: 750;
    text-transform: uppercase;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__title {
    max-width: 720px;
    margin: 0;
    color: inherit;
    font-size: clamp(2.15rem, 5vw, 3.9rem);
    line-height: 1.02;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__text {
    max-width: 680px;
    margin-top: 16px;
    color: color-mix(in srgb, var(--resume-shop-text) 72%, transparent);
    font-size: 1rem;
    line-height: 1.55;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__text p {
    margin: 0;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 20px;
    text-decoration: none;
    font-weight: 750;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(22, 22, 24, 0.1);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__button--primary {
    background: var(--resume-shop-accent);
    color: #ffffff;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__button--secondary {
    border: 1px solid color-mix(in srgb, var(--resume-shop-text) 15%, transparent);
    background: #ffffff;
    color: var(--resume-shop-text);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__panel {
    min-height: 280px;
    padding: 26px;
    display: grid;
    align-content: space-between;
    overflow: hidden;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--resume-shop-accent) 13%, white), color-mix(in srgb, var(--resume-shop-accent) 8%, var(--resume-shop-card)));
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__shelf {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    align-items: end;
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__shelf span {
    min-height: 180px;
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 18px 36px rgba(22, 22, 24, 0.08);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__shelf span:nth-child(2) {
    min-height: 220px;
    background: color-mix(in srgb, var(--resume-shop-accent) 18%, white);
  }

  .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__note {
    width: fit-content;
    max-width: 100%;
    border-radius: 999px;
    padding: 10px 14px;
    background: #ffffff;
    color: var(--resume-shop-text);
    font-weight: 700;
  }

  @media screen and (min-width: 900px) {
    .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
      align-items: stretch;
      padding: 72px 0;
    }

    .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__content {
      padding: 44px;
    }
  }

  @media screen and (max-width: 749px) {
    .resume-shop-highlight-{{ section.id }} .resume-shop-highlight__button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Resume shop highlight",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta",
      "default": "Loja de resumos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "A loja continua pronta quando precisas de estudar agora."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Se precisas de estudar agora, os nossos resumos continuam disponíveis na loja.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botao",
      "default": "Ver resumos"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do botao"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Texto do botao secundario",
      "default": "Ver explicações"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Link do botao secundario"
    },
    {
      "type": "text",
      "id": "panel_text",
      "label": "Texto do painel",
      "default": "Resumos por disciplina"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#f7f4ee"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Cor do card",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor principal",
      "default": "#5f6df2"
    }
  ],
  "presets": [
    {
      "name": "Resume shop highlight"
    }
  ]
}
{% endschema %}
