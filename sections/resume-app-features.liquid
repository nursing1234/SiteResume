<section class="resume-app-features resume-app-features-{{ section.id }}">
  <div class="resume-app-features__inner">
    <div class="resume-app-features__header">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-app-features__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="resume-app-features__title">{{ section.settings.title | escape }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="resume-app-features__text">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="resume-app-features__grid">
      <div class="resume-app-features__reasons">
        <div class="resume-app-features__reasons-header">
          <p class="resume-app-features__reasons-eyebrow">{{ section.settings.reasons_eyebrow | escape }}</p>
          <h3 class="resume-app-features__reasons-title">{{ section.settings.reasons_title | escape }}</h3>
        </div>

        <div class="resume-app-features__reasons-grid">
          <article class="resume-app-features__reason-card">
            <span>{{ section.settings.reason_1_icon | escape }}</span>
            <h4>{{ section.settings.reason_1_title | escape }}</h4>
            <p>{{ section.settings.reason_1_text | escape }}</p>
          </article>
          <article class="resume-app-features__reason-card">
            <span>{{ section.settings.reason_2_icon | escape }}</span>
            <h4>{{ section.settings.reason_2_title | escape }}</h4>
            <p>{{ section.settings.reason_2_text | escape }}</p>
          </article>
          <article class="resume-app-features__reason-card">
            <span>{{ section.settings.reason_3_icon | escape }}</span>
            <h4>{{ section.settings.reason_3_title | escape }}</h4>
            <p>{{ section.settings.reason_3_text | escape }}</p>
          </article>
        </div>
      </div>

      <div class="resume-app-features__tools">
      {% for block in section.blocks %}
        <article class="resume-app-features__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <span class="resume-app-features__icon">{{ block.settings.icon | escape }}</span>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="resume-app-features__card-title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="resume-app-features__card-text">{{ block.settings.text | escape }}</p>
          {% endif %}
        </article>
      {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .resume-app-features-{{ section.id }} {
    --resume-features-bg: {{ section.settings.background_color }};
    --resume-features-text: {{ section.settings.text_color }};
    --resume-features-accent: {{ section.settings.accent_color }};
    background: var(--resume-features-bg);
    color: var(--resume-features-text);
  }

  .resume-app-features-{{ section.id }} .resume-app-features__inner {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 56px 0;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__header {
    max-width: 820px;
    margin-bottom: 30px;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__eyebrow {
    margin: 0 0 10px;
    color: var(--resume-features-accent);
    font-size: 0.82rem;
    font-weight: 750;
    text-transform: uppercase;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__title {
    margin: 0;
    color: inherit;
    font-size: clamp(1.95rem, 4.2vw, 3.25rem);
    line-height: 1.05;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__text {
    margin-top: 14px;
    color: color-mix(in srgb, var(--resume-features-text) 72%, transparent);
    font-size: 1rem;
    line-height: 1.55;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__text p {
    margin: 0;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__grid {
    display: grid;
    gap: 22px;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reasons {
    border-radius: 26px;
    padding: 22px;
    background: color-mix(in srgb, var(--resume-features-accent) 8%, white);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--resume-features-accent) 12%, transparent);
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reasons-header {
    max-width: 650px;
    margin-bottom: 18px;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reasons-eyebrow {
    margin: 0 0 8px;
    color: var(--resume-features-accent);
    font-size: 0.78rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reasons-title {
    margin: 0;
    color: inherit;
    font-size: clamp(1.45rem, 3.2vw, 2.25rem);
    line-height: 1.05;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reasons-grid,
  .resume-app-features-{{ section.id }} .resume-app-features__tools {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 12px;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reason-card {
    border-radius: 22px;
    padding: 20px;
    background: color-mix(in srgb, white 88%, transparent);
    box-shadow: 0 14px 34px rgba(22, 22, 24, 0.06);
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reason-card span {
    display: inline-flex;
    margin-bottom: 14px;
    font-size: 1.25rem;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reason-card h4 {
    margin: 0;
    color: inherit;
    font-size: 1.12rem;
    line-height: 1.2;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__reason-card p {
    margin: 10px 0 0;
    color: color-mix(in srgb, var(--resume-features-text) 68%, transparent);
    line-height: 1.45;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__card {
    min-height: 172px;
    border: 1px solid color-mix(in srgb, var(--resume-features-text) 10%, transparent);
    border-radius: 24px;
    padding: 22px;
    background: color-mix(in srgb, white 92%, transparent);
    box-shadow: 0 14px 40px rgba(22, 22, 24, 0.055);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--resume-features-accent) 24%, transparent);
    box-shadow: 0 20px 46px rgba(22, 22, 24, 0.09);
  }

  .resume-app-features-{{ section.id }} .resume-app-features__icon {
    width: 40px;
    height: 40px;
    border-radius: 15px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    background: color-mix(in srgb, var(--resume-features-accent) 14%, white);
    color: var(--resume-features-accent);
    font-size: 0.95rem;
    font-weight: 850;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__card-title {
    margin: 0;
    color: inherit;
    font-size: 1.08rem;
    line-height: 1.2;
  }

  .resume-app-features-{{ section.id }} .resume-app-features__card-text {
    margin: 10px 0 0;
    color: color-mix(in srgb, var(--resume-features-text) 68%, transparent);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  @media screen and (min-width: 640px) {
    .resume-app-features-{{ section.id }} .resume-app-features__reasons-grid,
    .resume-app-features-{{ section.id }} .resume-app-features__tools {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .resume-app-features-{{ section.id }} .resume-app-features__inner {
      padding: 66px 0;
    }

    .resume-app-features-{{ section.id }} .resume-app-features__grid {
      gap: 28px;
    }

    .resume-app-features-{{ section.id }} .resume-app-features__reasons {
      padding: 30px;
    }

    .resume-app-features-{{ section.id }} .resume-app-features__reasons-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .resume-app-features-{{ section.id }} .resume-app-features__tools {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }
  }
</style>

