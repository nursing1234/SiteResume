      "default": "<p>Ferramentas simples para rever materia, praticar, preparar exames e acompanhar o progresso.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "accent_color",
