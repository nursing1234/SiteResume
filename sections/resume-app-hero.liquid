<section class="resume-app-hero resume-app-hero-{{ section.id }}">
  <div class="resume-app-hero__inner">
    <div class="resume-app-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="resume-app-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 class="resume-app-hero__title">{{ section.settings.title | escape }}</h1>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <div class="resume-app-hero__subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}

      <div class="resume-app-hero__badges" aria-label="{{ section.settings.badges_label | escape }}">
        {% assign badges = section.settings.badges | split: ',' %}
        {% for badge in badges %}
          {% assign badge_text = badge | strip %}
          {% if badge_text != blank %}
            <span class="resume-app-hero__badge">{{ badge_text | escape }}</span>
          {% endif %}
        {% endfor %}
      </div>

      <div class="resume-app-hero__actions">
        {% if section.settings.primary_label != blank %}
          <a class="resume-app-hero__button resume-app-hero__button--primary" href="{{ section.settings.primary_link | default: '#' }}">
            {{ section.settings.primary_label | escape }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank %}
          <a class="resume-app-hero__button resume-app-hero__button--secondary" href="{{ section.settings.secondary_link | default: '#' }}">
            {{ section.settings.secondary_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="resume-app-hero__visual">
      <div class="resume-app-hero__floating resume-app-hero__floating--one">
        <strong>{{ section.settings.float_card_1 | default: 'IA' | escape }}</strong>
        <span>{{ section.settings.float_card_1_text | default: 'Explica a matéria' | escape }}</span>
      </div>
      <div class="resume-app-hero__floating resume-app-hero__floating--two">
        <strong>{{ section.settings.float_card_2 | default: 'Exames' | escape }}</strong>
        <span>{{ section.settings.float_card_2_text | default: 'Treino focado' | escape }}</span>
      </div>
      <div class="resume-app-hero__mockup">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '360, 540, 720, 960, 1200',
              sizes: '(min-width: 990px) 44vw, 88vw',
              class: 'resume-app-hero__image',
              loading: 'eager',
              alt: section.settings.image.alt
          }}
        {% else %}
          <div class="resume-app-hero__placeholder" aria-hidden="true">
            <div class="resume-app-hero__phone-top"></div>
            <div class="resume-app-hero__placeholder-card resume-app-hero__placeholder-card--wide"></div>
            <div class="resume-app-hero__placeholder-grid">
              <span></span>
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="resume-app-hero__placeholder-card"></div>
          </div>
        {% endif %}
      </div>
      <div class="resume-app-hero__floating resume-app-hero__floating--three">
        <strong>{{ section.settings.float_card_3 | default: 'Quizzes' | escape }}</strong>
        <span>{{ section.settings.float_card_3_text | default: 'Testa o que sabes' | escape }}</span>
      </div>
      <div class="resume-app-hero__floating resume-app-hero__floating--four">
        <strong>{{ section.settings.float_card_4 | default: 'Resumos' | escape }}</strong>
        <span>{{ section.settings.float_card_4_text | default: 'Prontos a usar' | escape }}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .resume-app-hero-{{ section.id }} {
    --resume-hero-bg: {{ section.settings.background_color }};
    --resume-hero-text: {{ section.settings.text_color }};
    --resume-hero-accent: {{ section.settings.accent_color }};
    --resume-hero-soft: {{ section.settings.soft_color }};
    background:
      radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--resume-hero-accent) 15%, transparent), transparent 30%),
      linear-gradient(135deg, var(--resume-hero-bg), color-mix(in srgb, var(--resume-hero-soft) 58%, white));
    color: var(--resume-hero-text);
    overflow: hidden;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__inner {
    width: min(1200px, calc(100% - 32px));
    margin: 0 auto;
    padding: 58px 0 48px;
    display: grid;
    gap: 42px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    position: relative;
    z-index: 2;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__eyebrow {
    margin: 0;
    color: var(--resume-hero-accent);
    border: 1px solid color-mix(in srgb, var(--resume-hero-accent) 22%, transparent);
    border-radius: 999px;
    padding: 8px 12px;
    background: color-mix(in srgb, white 72%, transparent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__title {
    max-width: 820px;
    margin: 0;
    color: inherit;
    font-size: clamp(3rem, 11vw, 6.6rem);
    line-height: 0.9;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__subtitle {
    max-width: 680px;
    color: color-mix(in srgb, var(--resume-hero-text) 78%, transparent);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.55;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__subtitle p {
    margin: 0;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__badges,
  .resume-app-hero-{{ section.id }} .resume-app-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__badge {
    border: 1px solid color-mix(in srgb, var(--resume-hero-accent) 28%, transparent);
    border-radius: 999px;
    padding: 9px 13px;
    background: color-mix(in srgb, var(--resume-hero-soft) 66%, white);
    color: var(--resume-hero-text);
    font-size: 0.9rem;
    font-weight: 750;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__actions {
    padding-top: 8px;
    width: 100%;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__button {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 24px;
    text-decoration: none;
    font-weight: 850;
    box-shadow: 0 14px 30px rgba(20, 20, 30, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 38px rgba(20, 20, 30, 0.12);
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__button--primary {
    background: var(--resume-hero-accent);
    color: #ffffff;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__button--secondary {
    border: 1px solid color-mix(in srgb, var(--resume-hero-text) 20%, transparent);
    color: var(--resume-hero-text);
    background: color-mix(in srgb, white 86%, transparent);
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__visual {
    display: grid;
    place-items: center;
    position: relative;
    min-height: 430px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__mockup {
    width: min(86%, 500px);
    border: 1px solid color-mix(in srgb, white 78%, transparent);
    border-radius: 34px;
    padding: 16px;
    background: color-mix(in srgb, white 72%, var(--resume-hero-soft));
    box-shadow: 0 28px 90px rgba(26, 29, 36, 0.16);
    transform: rotate(1.5deg);
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 24px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__placeholder {
    min-height: 390px;
    border-radius: 20px;
    padding: 20px;
    background: #ffffff;
    display: grid;
    gap: 18px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__phone-top {
    width: 72px;
    height: 8px;
    border-radius: 99px;
    background: color-mix(in srgb, var(--resume-hero-text) 16%, transparent);
    justify-self: center;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__placeholder-card {
    min-height: 86px;
    border-radius: 18px;
    background: var(--resume-hero-soft);
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__placeholder-card--wide {
    min-height: 124px;
    background: color-mix(in srgb, var(--resume-hero-accent) 16%, var(--resume-hero-soft));
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__placeholder-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__placeholder-grid span {
    min-height: 74px;
    border-radius: 16px;
    background: color-mix(in srgb, var(--resume-hero-text) 7%, var(--resume-hero-soft));
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating {
    position: absolute;
    z-index: 2;
    width: max-content;
    max-width: 168px;
    border: 1px solid color-mix(in srgb, var(--resume-hero-text) 9%, transparent);
    border-radius: 20px;
    padding: 12px 14px;
    background: color-mix(in srgb, white 82%, transparent);
    box-shadow: 0 18px 40px rgba(26, 29, 36, 0.13);
    backdrop-filter: blur(10px);
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating strong,
  .resume-app-hero-{{ section.id }} .resume-app-hero__floating span {
    display: block;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating strong {
    color: var(--resume-hero-accent);
    font-size: 0.98rem;
    line-height: 1.1;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating span {
    margin-top: 4px;
    color: color-mix(in srgb, var(--resume-hero-text) 72%, transparent);
    font-size: 0.78rem;
    line-height: 1.25;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating--one {
    top: 8%;
    left: 0;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating--two {
    top: 20%;
    right: 0;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating--three {
    bottom: 17%;
    left: 3%;
  }

  .resume-app-hero-{{ section.id }} .resume-app-hero__floating--four {
    right: 3%;
    bottom: 5%;
  }

  @media screen and (min-width: 900px) {
    .resume-app-hero-{{ section.id }} .resume-app-hero__inner {
      min-height: 720px;
      grid-template-columns: minmax(0, 1.08fr) minmax(340px, 0.92fr);
      align-items: center;
      padding: 78px 0 64px;
    }
  }

  @media screen and (max-width: 749px) {
    .resume-app-hero-{{ section.id }} .resume-app-hero__actions {
      flex-direction: column;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__button {
      width: 100%;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__visual {
      min-height: 390px;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__mockup {
      width: min(78%, 340px);
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__floating {
      max-width: 138px;
      padding: 10px 11px;
      border-radius: 16px;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__floating--one {
      top: 2%;
      left: 0;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__floating--two {
      top: 10%;
      right: 0;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__floating--three {
      bottom: 12%;
      left: 0;
    }

    .resume-app-hero-{{ section.id }} .resume-app-hero__floating--four {
      right: 0;
      bottom: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Resume app hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etiqueta",
      "default": "Resume app"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titulo",
      "default": "A forma mais inteligente de estudar."
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "<p>Resumos, IA, quizzes, flashcards, exames nacionais e explicacoes. Tudo num so lugar.</p>"
    },
    {
      "type": "text",
      "id": "badges",
      "label": "Badges separados por virgula",
      "default": "IA, Quizzes, Exames, Flashcards"
    },
    {
      "type": "text",
      "id": "badges_label",
      "label": "Nome acessivel dos badges",
      "default": "Funcionalidades da app"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Texto do botao principal",
      "default": "Descarregar app"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Link do botao principal"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Texto do botao secundario",
      "default": "Ver resumos"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link do botao secundario"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem ou mockup"
    },
    {
      "type": "header",
      "content": "Cards flutuantes"
    },
    {
      "type": "text",
      "id": "float_card_1",
      "label": "Card 1 titulo",
      "default": "IA"
    },
    {
      "type": "text",
      "id": "float_card_1_text",
      "label": "Card 1 texto",
      "default": "Explica a materia"
    },
    {
      "type": "text",
      "id": "float_card_2",
      "label": "Card 2 titulo",
      "default": "Exames"
    },
    {
      "type": "text",
      "id": "float_card_2_text",
      "label": "Card 2 texto",
      "default": "Treino focado"
    },
    {
      "type": "text",
      "id": "float_card_3",
      "label": "Card 3 titulo",
      "default": "Quizzes"
    },
    {
      "type": "text",
      "id": "float_card_3_text",
      "label": "Card 3 texto",
      "default": "Testa o que sabes"
    },
    {
      "type": "text",
      "id": "float_card_4",
      "label": "Card 4 titulo",
      "default": "Resumos"
    },
    {
      "type": "text",
      "id": "float_card_4_text",
      "label": "Card 4 texto",
      "default": "Prontos a usar"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#f7f4ee"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor principal",
      "default": "#5f6df2"
    },
    {
      "type": "color",
      "id": "soft_color",
      "label": "Cor suave",
      "default": "#ebe8ff"
    }
  ],
  "presets": [
    {
      "name": "Resume app hero"
    }
  ]
}
{% endschema %}
